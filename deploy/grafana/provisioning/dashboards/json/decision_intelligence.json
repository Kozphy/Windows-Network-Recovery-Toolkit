{
  "title": "Decision Intelligence",
  "uid": "er-decision-intelligence",
  "tags": ["endpoint-reliability", "decision-intelligence", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "description": "Decision Intelligence API — events, decisions, accuracy, failures, latency. Ordinal accuracy is not calibrated probability.",
  "panels": [
    {
      "id": 1,
      "title": "Events total",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "events_total", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "Decisions total",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "decisions_total", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "Decision accuracy",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit"}},
      "targets": [{"expr": "decision_accuracy", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Decision failures",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "decision_failures", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "Event ingest rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [
        {"expr": "rate(events_total[5m])", "legendFormat": "events/s", "refId": "A"},
        {"expr": "rate(decisions_total[5m])", "legendFormat": "decisions/s", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "Decision latency (mean handler seconds)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [{"expr": "decision_latency_seconds", "legendFormat": "mean latency", "refId": "A"}]
    },
    {
      "id": 7,
      "title": "Failure rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "rate(decision_failures[5m])", "legendFormat": "failures/s", "refId": "A"}]
    },
    {
      "id": 8,
      "title": "Accuracy over time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit"}},
      "targets": [{"expr": "decision_accuracy", "legendFormat": "accuracy", "refId": "A"}]
    }
  ]
}
