{
  "title": "System Health",
  "uid": "er-system-health",
  "tags": ["endpoint-reliability", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "rate(platform_http_requests_total[5m])", "refId": "A"}]
    },
    {
      "id": 2,
      "title": "Endpoints (fleet gauge)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "platform_endpoint_count", "refId": "A"}]
    },
    {
      "id": 3,
      "title": "Incident clusters",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "platform_incident_cluster_count", "refId": "A"}]
    },
    {
      "id": 4,
      "title": "Heartbeats",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "Prometheus"},
      "targets": [{"expr": "platform_endpoint_heartbeat_total", "refId": "A"}]
    },
    {
      "id": 5,
      "title": "Readiness / liveness note",
      "type": "text",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 6},
      "options": {
        "content": "Probe **GET /platform/health** (liveness) and **GET /platform/ready** (startup checks). Metrics improve situational confidence — they do not replace proof-tier telemetry.",
        "mode": "markdown"
      }
    }
  ]
}
