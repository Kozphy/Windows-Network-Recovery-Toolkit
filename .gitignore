# Python
# -----------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyc
*.egg-info/
.pytest_cache/
.pytest-tmp/
.coverage
coverage/
htmlcov/

# Virtual environments
.venv/
venv/

# Node / frontend build
node_modules/
.next/
dist/
build/
.cache/

# Environment secrets (keep examples)
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# Runtime output (local only — never commit real machine data)
*.log
*.tmp
logs/
!logs/.gitignore
reports/
!reports/.gitignore
!reports/sample_*.md
!src/reports/
!src/reports/**
src/reports/**/__pycache__/
src/reports/**/*.py[cod]
!analytics/powerbi/reports/
!analytics/powerbi/reports/**
platform_data/
platform_data_fleet_demo/
data/failure_blocks/
!data/failure_blocks/.gitignore
!platform_data/.gitkeep

# Operator-generated snapshots (use *.example.json in repo)
config/last_known_good_proxy.json

# JSONL audit/runtime exports — allow synthetic demo fixtures only
*.jsonl
!tests/fixtures/**/*.jsonl
!examples/**/*.jsonl
!windows_network_toolkit/examples/*.jsonl
!demo_data/**/*.jsonl

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Large / binary artifacts
*.sqlite
trisk_local.db
schemathesis-junit.xml
schemathesis-run.log
*.zip
*.exe
*.msi

# Tests and committed synthetic fixtures remain visible (see negated *.jsonl above).

# Demo output artifacts (keep directory structure via .gitkeep)
demo-output/*
!demo-output/.gitkeep
!demo-output/audit/
demo-output/audit/*
!demo-output/audit/.gitkeep
!demo-output/reports/
demo-output/reports/*
!demo-output/reports/.gitkeep
!demo-output/timelines/
demo-output/timelines/*
!demo-output/timelines/.gitkeep
