        },
        "validation_id": {
          "title": "Validation Id",
          "type": "string"
        },
        "timestamp_utc": {
          "title": "Timestamp Utc",
          "type": "string"
        },
        "status": {
          "default": "not_run",
          "enum": [
            "passed",
            "failed",
            "inconclusive",
