          "type": "object"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "required": [
        "observation_id",
        "timestamp_utc",
        "source"
      ],
      "title": "ObservationStage",
      "type": "object"
    },
    "OutcomeStage": {
      "description": "Recorded result after decision/execution.",
