          "title": "Records",
          "type": "array"
        },
        "recommended_controls": {
          "items": {
            "type": "string"
          },
          "title": "Recommended Controls",
          "type": "array"
        },
        "recommended_tests": {
          "items": {
            "type": "string"
          },
          "title": "Recommended Tests",
          "type": "array"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "title": "LearningStage",
      "type": "object"
    },
    "ObservationStage": {
      "description": "Raw signals \u2014 observation is not proof.",
      "properties": {
        "stage": {
          "const": "observation",
          "default": "observation",
          "title": "Stage",
          "type": "string"
        },
        "observation_id": {
          "title": "Observation Id",
          "type": "string"
        },
        "timestamp_utc": {
          "title": "Timestamp Utc",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "symptom": {
          "default": "",
          "title": "Symptom",
          "type": "string"
        },
        "raw_signals": {
          "additionalProperties": true,
