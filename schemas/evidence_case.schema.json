        "stage": {
          "const": "outcome",
          "default": "outcome",
          "title": "Stage",
          "type": "string"
        },
        "outcome": {
          "anyOf": [
            {
              "$ref": "#/$defs/IncidentOutcome"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "resolution_summary": {
          "default": "",
          "title": "Resolution Summary",
          "type": "string"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        }
      },
      "title": "OutcomeStage",
      "type": "object"
    },
    "PolicyEvaluation": {
