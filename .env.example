# =============================================================================
# Endpoint Reliability Platform — service configuration
# Copy to `.env` in repo root or `backend/.env` for local / Docker runs.
# =============================================================================

# Safety (keep enabled in production-shaped deployments)
PLATFORM_SAFE_MODE=1

# Append-only JSONL storage root
PLATFORM_DATA_DIR=./platform_data

# PostgreSQL (optional — Decision Intelligence API uses JSONL when unset)
# DATABASE_URL=postgresql://di:di@localhost:5432/decision_intelligence
# POSTGRES_USER=di
# POSTGRES_PASSWORD=di
# POSTGRES_DB=decision_intelligence

# Optional Bearer auth for /platform/* (unset = header RBAC only)
# PLATFORM_API_KEY=change-me-in-production

# Fail process start when startup checks report hard failures
FAIL_FAST_ON_STARTUP=0

# Comma-separated CORS origins (* for local demos only)
CORS_ALLOW_ORIGINS=*

# Service metadata (OpenAPI / health)
SERVICE_NAME=endpoint-reliability-platform
SERVICE_VERSION=1.0.0

# Require ping binary on PATH (Docker Linux images install iputils-ping)
REQUIRE_PING_BINARY=0

# Grafana (docker compose)
# GRAFANA_ADMIN_PASSWORD=change-me
